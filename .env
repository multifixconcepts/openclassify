# App Configuration
APP_NAME="OpenClassify"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=openclassify
DB_USERNAME=openclassify
DB_PASSWORD=secret123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Reverb Configuration
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=local_app_id
REVERB_APP_KEY=local_app_key
REVERB_APP_SECRET=local_app_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Demo Mode (set to 0 for production)
DEMO=0
